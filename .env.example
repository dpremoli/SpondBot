# Spond credentials
SPOND_USERNAME=your@email.com
SPOND_PASSWORD=yourpassword

# Group that contains the Sunday Social events
SPOND_GROUP_ID=your_group_id_here

# Local wall-clock time the invites typically go out (HH:MM or HH:MM:SS).
# The bot starts rapid polling 30s before this and accepts 0.7s after detection.
SPOND_INVITE_TIME=09:00

# Container timezone — keep this matching SPOND_INVITE_TIME's wall clock.
TZ=Europe/London
